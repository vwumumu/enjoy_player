<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>$(PRODUCT_COPYRIGHT)</string>
	<key>NSMainNibFile</key>
	<string>MainMenu</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Enjoy Player uses the microphone for shadow-reading practice recordings.</string>
	<key>SUPublicEDKey</key>
	<string>XnT9Tv0IiX0mWTgWUGu8wit0C+6+G27hSCaCD3OTjWY=</string>
	<key>FlutterDeepLinkingEnabled</key>
	<true/>
	<!--
	  TODO(google-oauth): GIDClientID must be a real macOS-type OAuth client ID
	  created in Google Cloud Console for bundle ID ai.enjoy.player, matching
	  `google.macos_client_id` (or `ios_client_id` as fallback) in enjoy_web's
	  Rails credentials. The second CFBundleURLSchemes entry below must be
	  that client ID reversed, e.g.
	  "com.googleusercontent.apps.<CLIENT_ID_PREFIX>" (see
	  https://developers.google.com/identity/sign-in/ios/start-integrating).
	-->
	<key>GIDClientID</key>
	<string>REPLACE_WITH_MACOS_OAUTH_CLIENT_ID.apps.googleusercontent.com</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>ai.enjoy.player.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>enjoyplayer</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>ai.enjoy.player.google-signin</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>REPLACE_WITH_REVERSED_MACOS_CLIENT_ID</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
